# ============================================================
# ICT Trading Bot — Environment Variables
# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.
# ============================================================

# ── CCXT (Crypto — Binance, Bybit, OKX, etc.) ────────────
# Required only for LIVE ccxt orders (not needed for paper trading)
CCXT_API_KEY=your_api_key_here
CCXT_API_SECRET=your_api_secret_here

# ── OANDA (Forex) ─────────────────────────────────────────
# Get from: https://www.oanda.com/demo-account/ (practice) or live account
OANDA_ACCESS_TOKEN=your_oanda_token_here
OANDA_ACCOUNT_ID=your_oanda_account_id_here

# ── Telegram Alerts (optional) ────────────────────────────
# Create a bot via @BotFather, then get chat_id via @userinfobot
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
